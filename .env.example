# Sarathi — Environment Variables
# Copy to .env and fill in your values.

# LLM
GOOGLE_API_KEY="your-google-api-key-here"
LLM_MODEL_NAME="gemini-flash-latest"

# RAG Pipeline
EMBEDDING_MODEL_NAME="BAAI/bge-m3"
CHROMA_DISTANCE_SPACE="cosine"
RETRIEVAL_TOP_K=8
MAX_CONTEXT_CHUNKS=5
RELEVANCE_THRESHOLD=0.85

# GPU / Torch
USE_GPU="auto"                  # "true" | "false" | "auto"
STRICT_CUDA_FOR_INGEST="true"
EXPECTED_CUDA_NAME="RTX 3060"
STRICT_SAFE_TORCH="true"
MIN_SAFE_TORCH_VERSION="2.6.0"

# Rasa Action Server
RAG_API_URL="http://localhost:8000/query/"
RAG_API_TIMEOUT_SECONDS=180
RAG_QUERY_SOURCE="rasa_action_server"
RAG_SEND_PROGRESS_MESSAGE="false"

# Logging
INGEST_LOG_LEVEL="INFO"
RAG_LOG_LEVEL="INFO"
